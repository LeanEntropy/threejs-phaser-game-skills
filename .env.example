# API keys for game-skills generators. Copy to .env (gitignored) or ~/.config/game-skills/.env
# OpenAI GPT-Image (gpt-image-1) — phaser image/sprite generators + threejs-image-generator-openai
OPENAI_API_KEY=
# Google Gemini — phaser image/sprite generators + upstream threejs-image-generator
GEMINI_API_KEY=
# ElevenLabs — phaser/threejs audio generators
ELEVENLABS_API_KEY=
# Tripo — upstream threejs-3d-generator (3D only)
TRIPO_API_KEY=
